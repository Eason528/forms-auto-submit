name: 定时提交问卷

on:
  schedule:
    - cron: '0 2 * * 2'
  workflow_dispatch:

jobs:
  submit:
    runs-on: ubuntu-latest
    
    steps:
      - name: 获取代码
        uses: actions/checkout@v4
      
      - name: 设置 Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'
      
      - name: 安装依赖
        run: |
          pip install selenium webdriver-manager
      
      - name: 运行脚本
        run: python forms_filler.py
        env:
          MOZ_HEADLESS: 1
